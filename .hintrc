{
  "extends": [
    "development"
  ],
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 26.5",
    "not safari <= 26.4"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "mask-image",
          "user-select"
        ]
      }
    ],
    "axe/aria": [
      "default",
      {
        "aria-valid-attr-value": "off"
      }
    ]
  }
}